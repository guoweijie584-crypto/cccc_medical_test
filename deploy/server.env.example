# Copy to /etc/cccc-test.env (or another path) and edit values to match your server.

PROJECT_ROOT=/srv/cccc_test/app
VENV_DIR=/srv/cccc_test/venv

# Repo-local runtime state
CCCC_HOME=/srv/cccc_test/app/.cccc_home
CCCC_NATIVE_HOME=/srv/cccc_test/app/.cccc_home

# Keep the vendored cccc runtime ahead of site-packages.
PYTHONPATH=/srv/cccc_test/app/cccc_medical-main/src

# Runtime ports
CCCC_DAEMON_PORT=9766
CCCC_WEB_HOST=127.0.0.1
CCCC_WEB_PORT=8858
MEMORY_PALACE_HOST=127.0.0.1
MEMORY_PALACE_PORT=8000

# Runtime secrets / model config
MCP_API_KEY=change-me
LLM_API_KEY=change-me
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Optional web/external binding
SERVER_NAME=your.server.example.com
